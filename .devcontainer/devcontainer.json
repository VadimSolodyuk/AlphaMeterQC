{
  "name": "AlphaMeterQC Dev Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "postCreateCommand": "git config --global user.name 'VadimSolodyuk' && git config --global user.email 'vadim.l.solodyuk@gmail.com' && pre-commit install && chmod +x scripts/*.sh 2>/dev/null || true && scripts/check_env.sh || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.isort",
        "ms-python.flake8",
        "ms-python.mypy-type-checker",
        "github.vscode-github-actions",
        "eamodio.gitlens",
        "redhat.vscode-yaml",
        "bierner.markdown-preview-github-styles",
        "shardulm94.trailing-spaces",
        "ms-ceintl.vscode-language-pack-ru",
        "Alibaba-Cloud.tongyi-lingma"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  },
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "remoteUser": "vscode"
}