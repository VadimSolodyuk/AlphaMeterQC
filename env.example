# =============================================================================
# КОНФИГУРАЦИЯ OKRUZHENIYA AlphaMeterQC
# =============================================================================
# Скопируйте этот файл в .env и заполните актуальными значениями:
# cp .env.example .env

# -----------------------------------------------------------------------------
# AI МОДЕЛИ И СЕРВИСЫ
# -----------------------------------------------------------------------------

# Адрес Ollama API (локальный сервер)
OLLAMA_BASE_URL=http://localhost:11434

# Модель по умолчанию для AI-запросов
# Доступные варианты: qwen2.5:7b, llama3.2, mistral, codellama и др.
AI_MODEL=qwen2.5:7b

# Таймаут запросов к AI (в секундах)
AI_TIMEOUT=120

# Максимальное количество токенов в ответе
AI_MAX_TOKENS=2048

# Температура генерации (0.0 - детерминировано, 1.0 - креативно)
AI_TEMPERATURE=0.7

# -----------------------------------------------------------------------------
# ЛОГИРОВАНИЕ
# -----------------------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Путь к файлу логов (оставьте пустым для вывода в консоль)
# LOG_FILE=logs/alphameterqc.log

# -----------------------------------------------------------------------------
# БАЗА ДАННЫХ (если используется)
# -----------------------------------------------------------------------------

# DATABASE_URL=sqlite:///data/alphameterqc.db
# DATABASE_URL=postgresql://user:password@localhost:5432/alphameterqc

# -----------------------------------------------------------------------------
# GUI НАСТРОЙКИ
# -----------------------------------------------------------------------------

# Тема интерфейса: light, dark, system
GUI_THEME=system

# Масштабирование интерфейса: 100%, 110%, 120% и т.д.
GUI_SCALE=100%
