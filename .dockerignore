# =============================================================================
# .dockerignore - Файлы и папки, исключаемые из Docker контекста
# =============================================================================
# Это ускоряет сборку образа и уменьшает его размер
# =============================================================================

# Dev Containers (не копируем саму папку .devcontainer внутрь контейнера)
# Но Dockerfile и devcontainer.json нужны для сборки, поэтому не исключаем .devcontainer/

# === Проектные файлы (временные) ===
project_structure.txt
prompt/

# === Кэш и временные файлы ===
*.tmp
*.log
*.bak

# === Конфигурация подключения (безопасность) ===
connection.json
*.local.json

# Виртуальные окружения
venv/
.venv/
env/
ENV/

# Git
.git/
.gitignore

# IDE
#.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/

# Документация (генерируемая)
site/

# OS
.DS_Store
Thumbs.db


# Скрипты сборки
dist/
build/
*.spec

# Тестирование и покрытие
.coverage
.coverage.*
htmlcov/
